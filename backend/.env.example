# Server
PORT=4000
NODE_ENV=development

# Database (Supabase/PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/cedig

# Firebase Admin SDK
FIREBASE_PROJECT_ID=cedig-family-tree
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@cedig-family-tree.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AWS S3
# AWS_REGION: General AWS region (shared across services)
# AWS_S3_REGION: S3 bucket-specific region (falls back to AWS_REGION if not set)
# Both must match the actual bucket region to avoid PermanentRedirect errors
AWS_REGION=us-east-1
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET_NAME=cedig-uploads

# CORS
CORS_ORIGIN=http://localhost:3000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@cedig.mn

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
