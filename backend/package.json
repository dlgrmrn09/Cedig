{
  "name": "cedig-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "CEDIG Family Tree Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js",
    "migrate:seed": "node src/database/migrate.js && node src/database/seed.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit --detectOpenHandles",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration --forceExit --detectOpenHandles",
    "test:auth": "node --experimental-vm-modules node_modules/.bin/jest tests/auth --forceExit --detectOpenHandles",
    "lint": "eslint src/"
  },
  "keywords": [
    "cedig",
    "family-tree",
    "mongolian",
    "genealogy"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.6.0",
    "google-auth-library": "^9.15.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.15",
    "pg": "^8.13.0",
    "socket.io": "^4.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.43",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [],
    "moduleNameMapper": {}
  }
}
